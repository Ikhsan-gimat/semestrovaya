from main import Deque
def test_example():
    assert 1 + 1 == 2




def test_push_front():
    dq = Deque(4)
    dq.push_front(10)
    assert dq.to_list() == [10]
    assert dq.size() == 1


def test_push_back():
    dq = Deque(4)
    dq.push_back(20)
    assert dq.to_list() == [20]
    assert dq.size() == 1


def test_pop_front():
    dq = Deque(4)
    dq.push_back(10)
    dq.push_back(20)

    value = dq.pop_front()

    assert value == 10
    assert dq.to_list() == [20]
    assert dq.size() == 1


def test_pop_back():
    dq = Deque(4)
    dq.push_back(10)
    dq.push_back(20)

    value = dq.pop_back()

    assert value == 20
    assert dq.to_list() == [10]
    assert dq.size() == 1


def test_peek_front():
    dq = Deque(4)
    dq.push_back(10)
    dq.push_back(20)

    assert dq.peek_front() == 10
    assert dq.to_list() == [10, 20]


def test_peek_back():
    dq = Deque(4)
    dq.push_back(10)
    dq.push_back(20)

    assert dq.peek_back() == 20
    assert dq.to_list() == [10, 20]


def test_is_empty():
    dq = Deque(4)
    assert dq.is_empty() is True

    dq.push_back(1)
    assert dq.is_empty() is False


def test_is_full():
    dq = Deque(2)
    assert dq.is_full() is False

    dq.push_back(1)
    dq.push_back(2)
    assert dq.is_full() is True


def test_size():
    dq = Deque(4)
    assert dq.size() == 0

    dq.push_back(1)
    dq.push_back(2)
    assert dq.size() == 2


def test_to_list():
    dq = Deque(5)
    dq.push_back(10)
    dq.push_back(20)
    dq.push_front(5)

    assert dq.to_list() == [5, 10, 20]
